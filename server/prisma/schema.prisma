model ScanMatchAudit {
  id                          String                  @id @default(uuid())
  createdAt                   DateTime                @default(now()) @map("created_date")
  updatedAt                   DateTime                @updatedAt @map("updated_date")
  label_scan_id               String // FK till LabelScan @map("label_scan_id")
  identifiers_searched        String[] // Alla identifierare (OCR + barcode-varianter + canonicals) som söktes
  matches_found               Json? // Alla träffar som hittades
  decision                    ScanMatchAuditDecision? // Vilket beslut togs
  confidence                  Float? // Kombinerad confidence vid beslutet
  pattern_rules_applied       String[] // IDs på BatchPatternRules som matchade
  supplier_inferred_from_rule String? // Leverantörsnamn infererat från mönsterregel
  timestamp                   DateTime?
  duration_ms                 Float? // Körtid för findExistingMatches i ms
  actor                       String? // Email på den som triggade scanningen
}

model ServiceLog {
  id               String                  @id @default(uuid())
