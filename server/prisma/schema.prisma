  rm_system_url             String? // Länk till ordern i RM-systemet
  status                    OrderStatus             @default(S_LJ) // Operativ orderstatus
  financial_status          OrderFinancial_status   @default(unbilled) // Ekonomisk status – faktureringläge
  delivery_date             DateTime? // Önskat leveransdatum
  delivery_address          String? // Leveransadress
  delivery_method           OrderDelivery_method? // Leveranssätt
  shipping_company          String? // Speditör/transportföretag
  tracking_number           String? // Spårningsnummer för leveransen
  shipped_date              DateTime? // Datum när ordern skickades
  delivery_contact_name     String? // Kontaktperson vid leveransplats
  delivery_contact_phone    String? // Telefon till kontaktperson vid leveransplats
  installation_date         DateTime? // Installationsdatum (om annat än leverans)
  installation_type         OrderInstallation_type? // Typ av installation
  screen_dimensions         String? // Skärmdimensioner (Bredd x Höjd mm)
  pixel_pitch               String? // Pixel pitch (t.ex. P2.6)
  module_count              Float? // Antal moduler
  critical_notes            String? // OBS / Viktigt för hela teamet (visas som gul varning i alla steg)
  site_ids                  String[] // Kopplade siter
  site_names                String[] // Kopplade sitenamn
  site_visit_info           String? // Information om platsbesök
  notes                     String? // Anteckningar
  picked_by                 String? // Plockad av (användarens email)
  picked_date               DateTime? // Plockdatum
  picking_started_date      DateTime? // När plockningen startades
  picking_started_by        String? // Vem som startade plockningen (email)
  production_started_date   DateTime? // När produktionen startade
  production_completed_date DateTime? // När produktionen avslutades
  needs_ordering            Boolean                 @default(false) // Kräver beställning
  ordering_completed        Boolean                 @default(false) // Beställning genomförd
  ordering_notes            String? // Beställningsanteckningar
  fortnox_invoiced          Boolean                 @default(false) // Ordern är fakturerad i Fortnox
  fortnox_invoice_number    String? // Fakturanummer från Fortnox
  fortnox_order_id          String? // Fortnox ordernummer @map("fortnox_order_id")
  fortnox_document_number   String? // Fortnox dokumentnummer
  fortnox_project_number    String? // Fortnox projektnummer
  fortnox_project_name      String? // Fortnox projektnamn/benämning
  invoiced_date             DateTime? // Datum när ordern fakturerades
  invoiced_by               String? // Vem som markerade ordern som fakturerad (email)
  is_incomplete             Boolean                 @default(false) // Order är ofullständig
  cancellation_reason       String? // Anledning till avbokning/annullering
  source_document_url       String? // Kundorder/PO originalfil
  uploaded_files            Json? // Alla uppladdade filer (ritningar, platsbilder, övrigt)
  sales_completed           Boolean                 @default(false) // Försäljning slutförd
  project_notes             String? // Projektanteckningar från CRM
}

