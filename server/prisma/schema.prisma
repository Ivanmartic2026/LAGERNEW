model KimiConfig {
  id                                 String   @id @default(uuid())
  createdAt                          DateTime @default(now()) @map("created_date")
  updatedAt                          DateTime @updatedAt @map("updated_date")
  model_name                         String   @default("moonshot-v1-8k-vision") // Kimi-modell att använda (moonshot-v1-8k-vision stödjer vision/bilder)
  api_base_url                       String   @default("https://api.moonshot.ai/v1") // Moonshot API bas-URL
  thinking_mode                      Boolean  @default(false) // Aktivera thinking mode — av för deterministisk label-parsing
  prompt_version                     String   @default("v1") // Version av prompt-template
  confidence_threshold_auto_approve  Float    @default(0.85) // Confidence-tröskel för automatiskt godkännande
  confidence_threshold_manual_review Float    @default(0.6) // Confidence-tröskel för manuell granskning
  max_retries                        Float    @default(2) // Max antal försök vid fel
  timeout_ms                         Float    @default(90000) // Timeout i millisekunder (90s)
  is_active                          Boolean  @default(true) // Om konfigurationen är aktiv
  cost_limit_per_run                 Float    @default(10) // USD-tak per bulk-omanalys
  monthly_cost_limit                 Float    @default(300) // USD-tak per månad
  current_month_spend                Float    @default(0) // Ackumulerad kostnad denna månad i USD
  current_month                      String? // YYYY-MM för att nollställa månadsbudget
  min_confidence_to_save_batch       Float    @default(0.4) // Minsta confidence för att spara Batch-post
}

model LabelScan {
  id                        String            @id @default(uuid())
  createdAt                 DateTime          @default(now()) @map("created_date")
  updatedAt                 DateTime          @updatedAt @map("updated_date")
  batch_id                  String? // Referens till Batch @map("batch_id")
  image_url                 String? // URL till bilden
  image_hash                String? // SHA-256 hash av bilden
  image_uploaded_by         String? // Uppladdad av (email)
  image_uploaded_at         DateTime? // Uppladdningstidpunkt
  ai_provider               String            @default("moonshot") // AI-leverantör
  ai_model_used             String? // Använd AI-modell
  ai_model_version          String? // Modellversion
  ai_prompt_version         String? // Prompt-version som användes
  ai_raw_response           Json? // Råsvar från AI (sparas oförändrat, inkl barcode_reads + ocr_regions)
  ai_processing_duration_ms Float? // Bearbetningstid i millisekunder
  ai_tokens_used            Float? // Antal tokens använda
  ai_cost_usd               Float? // Kostnad i USD
  extracted_fields          Json? // Extraherade fält från AI inkl barcode_values och ocr_regions
  field_confidence          Json? // Confidence per fält (0-1) + overall
  normalized_fields         Json? // Normaliserade fältvärden
  match_results             Json? // Matchningsresultat från Lager 2 ScanMatch-resolver
  status                    LabelScanStatus   @default(queued) // Bearbetningsstatus
  error_message             String? // Felmeddelande
  manual_corrections        Json? // Manuella korrigeringar av användaren
  corrected_by              String? // Korrigerad av (email)
  corrected_at              DateTime? // Korrigeringstidpunkt
  context                   LabelScanContext? // Scanning-kontext
  context_reference_id      String? // ID till kontextreferensen @map("context_reference_id")
}

model MergeApprovalQueue {
  id                  String                       @id @default(uuid())
  createdAt           DateTime                     @default(now()) @map("created_date")
  updatedAt           DateTime                     @updatedAt @map("updated_date")
  queue_type          MergeApprovalQueueQueue_type @default(article_duplicate) // Typ av dublett-merge
  candidate_ids       String[] // IDs på potentiella dubletter
  candidate_entity    String // Entity-namn, t.ex. Article eller Batch
  similarity_key      String? // Värde som gjorde klassificering, t.ex. batch_number
  winner_suggested_id String? // ID på post med högst coupling_count (förslag) @map("winner_suggested_id")
  coupling_counts     Json? // ID → coupling count mappning
  coupling_breakdown  Json? // Detaljerad breakdown per ID: {id: {po_items: n, receiving: n, repairs: n, orders: n, ...}}
  fields_diff         Json? // Visar fältskillnader: {field_name: {id1: value1, id2: value2, ...}}
  status              MergeApprovalQueueStatus     @default(pending_review) // Status på godkännande
  reviewed_by         String? // Granskad av (email)
  reviewed_at         DateTime? // Granskningstidpunkt
  review_notes        String? // Noteringar från granskning
  merge_executed      Boolean                      @default(false) // Om merge redan exekverad
  merge_executed_at   DateTime? // Tidpunkt för merge-exekvering
  rollback_snapshot   Json? // FULL snapshot av alla kandidat-poster + downstream-referenser INNAN merge
}

model MigrationRun {
  id                 String    @id @default(uuid())
  createdAt          DateTime  @default(now()) @map("created_date")
  updatedAt          DateTime  @updatedAt @map("updated_date")
  migration_name     String // Migrations-namn, t.ex. migrateArticleBatchNumbersToBatchEntity
  run_date           DateTime? // Körtidpunkt
  ran_by             String? // Kördes av (email)
  input_summary      Json? // Antal poster innan migration
  output_summary     Json? // Antal skapade/uppdaterade poster
  rollback_snapshot  Json? // FULL snapshot av förändrade poster för rollback
  rollback_available Boolean   @default(true) // Om rollback möjlig
  rolled_back        Boolean   @default(false) // Om redan rulladbak
  rolled_back_at     DateTime? // Rollback-tidpunkt
  errors             String[] // Felmeddelanden under migration
}

model Notification {
  id         String               @id @default(uuid())
  createdAt  DateTime             @default(now()) @map("created_date")
  updatedAt  DateTime             @updatedAt @map("updated_date")
  user_email String // Mottagarens email
  title      String // Notifieringens titel
  message    String // Notifieringsmeddelande
  type       NotificationType // Typ av notifiering
  priority   NotificationPriority @default(normal) // Prioritet
  is_read    Boolean              @default(false) // Om notifieringen är läst
  link_to    String? // Länk till relevant sida (t.ex. orderId, articleId)
  link_page  String? // Sidnamn att länka till
  metadata   Json? // Extra metadata
}

model NotificationSettings {
  id                     String   @id @default(uuid())
  createdAt              DateTime @default(now()) @map("created_date")
  updatedAt              DateTime @updatedAt @map("updated_date")
  user_email             String // Användarens email
  in_app_enabled         Boolean  @default(true) // In-app notifieringar aktiverade
