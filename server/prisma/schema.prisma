model Article {
  id                         String              @id @default(uuid())
  createdAt                  DateTime            @default(now()) @map("created_date")
  updatedAt                  DateTime            @updatedAt @map("updated_date")
  sku                        String? // Artikelnummer
  name                       String // Benämning
  supplier_id                String? // Referens till leverantör @map("supplier_id")
  supplier_name              String? // Leverantörens namn (för enklare sökning)
  unit_cost                  Float? // Enhetskostnad
  supplier_product_code      String? // Leverantörens produktkod
  category                   ArticleCategory? // Typ av artikel
  storage_type               ArticleStorage_type // Lagertyp
  dimensions_width_mm        Float? // Bredd (mm)
  dimensions_height_mm       Float? // Höjd (mm)
  dimensions_depth_mm        Float? // Djup (mm)
  weight_g                   Float? // Vikt (g)
  stock_qty                  Float? // I lager (antal)
  reserved_stock_qty         Float               @default(0) // Reserverat för pågående ordrar
  warehouse                  String? // Lagerställe
  shelf_address              String[] // Lagerplatser
  batch_number               String? // LEGACY — migreras till Batch-entity, används bara för sökning. Nya data skrivs till Batch.batch_number
  legacy_batch_number        String? // Sparad kopia av ursprunglig batch_number för auditspårning
  primary_batch_id           String? // Referens till primär Batch-post @map("primary_batch_id")
  ai_scan_count              Float               @default(0) // Antal AI-scanningar
  pixel_pitch_mm             Float? // Pixel Pitch (mm)
  customer_name              String? // Kundnamn/Marknadsnamn
  pitch_value                String? // Pixel pitch värde (t.ex. P1.95, P2.6)
  series                     ArticleSeries? // Produktserie/användning
  product_version            String? // Produktversion
  manufacturer               String? // Tillverkare
  manufacturing_date         DateTime? // Tillverkningsdatum
  brightness_nits            Float? // Ljusstyrka i nits
  status                     ArticleStatus       @default(active) // Artikelstatus
  transit_notes              String? // Anteckningar om transit/transport
  transit_expected_date      DateTime? // Förväntat ankomstdatum för transit
  image_urls                 String[] // Bilder på artikeln/etiketten
  notes                      String? // Anteckningar
  min_stock_level            Float? // Minsta lagernivå för varning
  repair_notes               String? // Anledning till reparation
  repair_date                DateTime? // Datum när artikel skickades på reparation
  cfg_file_url               String? // Länk till CFG-konfigurationsfil
  unknown_delivery_reference String? // Referensnummer för okänd inleverans
  delivery_date              DateTime? // Datum för inleverans
  assigned_to                String? // Vem som utreder den okända leveransen (email)
  ai_extracted_data          Json? // Ursprunglig AI-extraherad data från scanning
  ai_confidence_scores       Json? // AI confidence scores för extraherade fält
  source_invoice_url         String? // Länk till originalfaktura som artikeln skapades från
  source_invoice_number      String? // Fakturanummer som artikeln skapades från
  source_purchase_order_id   String? // Referens till inköpsorder som artikeln skapades från @map("source_purchase_order_id")
  fortnox_synced             Boolean             @default(false) // Om artikeln är synkad till Fortnox och kan auto-synkas
}

model Batch {
  id                    String               @id @default(uuid())
  createdAt             DateTime             @default(now()) @map("created_date")
  updatedAt             DateTime             @updatedAt @map("updated_date")
  batch_number          String // Normaliserat batchnummer (primärt index)
  raw_batch_number      String? // Originalt batchnummer exakt som det lästes
  article_id            String? // FK till Article (required, null endast om legacy_unmigrated=true) @map("article_id")
  article_sku           String? // Artikelnummer (SKU)
  article_name          String? // Artikelnamn
  supplier_id           String? // Referens till leverantör @map("supplier_id")
  supplier_name         String? // Leverantörsnamn
  supplier_source       BatchSupplier_source @default(unknown) // Hur leverantören identifierades
  purchase_order_id     String? // Referens till inköpsorder @map("purchase_order_id")
  receiving_record_id   String? // Referens till mottagningspost @map("receiving_record_id")
  quantity              Float? // Kvantitet
  manufacturing_date    DateTime? // Tillverkningsdatum
  expiry_date           DateTime? // Utgångsdatum
  production_date       DateTime? // Produktionsdatum
  batch_pattern         Json? // Mönsteranalys av batchnummer
  risk_score            Float                @default(0) // Riskpoäng 0-100
  risk_flags            String[] // Riskflaggor
  status                BatchStatus          @default(pending_verification) // Status på batchen
  verified_by           String? // Verifierad av (email)
  verified_at           DateTime? // Verifieringstidpunkt
  legacy_unmigrated     Boolean              @default(false) // Markerar poster skapade från migration men där artikelkopplingen är osäker
  merged_from_batch_ids String[] // Historik om batchen skapats genom auto-merge av dubletter
  coupling_count        Float                @default(0) // Antal kopplingar (PO-items, receiving, repair, orders, withdrawals)
  source_context        BatchSource_context  @default(manual) // Källa/kontext för batchen
  notes                 String? // Anteckningar
}

