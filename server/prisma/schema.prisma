  purchase_order_updates Boolean  @default(true) // Notifiering vid inköpsorder uppdateringar
  repair_updates         Boolean  @default(true) // Notifiering vid reparationsuppdateringar
  critical_only          Boolean  @default(false) // Endast kritiska notifieringar
  chat_mentions_push     Boolean  @default(true) // Push vid @omnämnanden i chatt
  chat_dm_push           Boolean  @default(true) // Push vid direktmeddelanden
  chat_all_messages_push Boolean  @default(false) // Push för alla nya meddelanden i prenumererade trådar
  quiet_hours_enabled    Boolean  @default(true) // Tysta timmar aktiverade
  quiet_hours_start      String   @default("22:00") // Start för tysta timmar (HH:MM)
  quiet_hours_end        String   @default("06:00") // Slut för tysta timmar (HH:MM)
}

model PushSubscription {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now()) @map("created_date")
  updatedAt  DateTime @updatedAt @map("updated_date")
  user_email String
  endpoint   String   @unique
  p256dh     String
  auth       String
  user_agent String?
  is_active  Boolean  @default(true)
}

model Order {
